<!--
  runPicoBinner_OO200_SDCC_template.xml - lightflavorspectra_OO200

  SDCC/RCF star-submit job description for stage 1 (PicoBinner) only, against a real
  production PicoDst dataset. This is the ONLY pipeline stage this repo runs on SDCC -
  ZFitter/RawSpectraModifier/SpectraFitter are run locally on a laptop against
  PicoBinner's output (see "Moving output back to a laptop" in the README's SDCC
  section).

  Restructured to follow the format of a real, working O+O 200 GeV job
  (lightflavorspectra_etof's pions_OO_200GeV job), including the <shell> singularity
  container line SDCC now requires and the filesPerHour attribute. library=/production=
  are kept at THIS repo's SL24y/P24iy port rather than reverting to that job's
  SL23c/P23ic - see the CATALOG QUERY note below. Paths are filled in for
  liggett2820's real SDCC/RCF username and scratch/pwg layout - if someone else runs
  this, update every /liggett path below.

  *** BEFORE SUBMITTING: rebuild this repo's libraries ON THE SDCC/RCF NODE ***
  The .so files this template packages (see <SandBox> below) are NOT committed to
  git (see .gitignore) because the ones on a laptop are macOS/arm64 Mach-O binaries -
  they will not load on BNL's Linux nodes. After cloning this repo onto SDCC, run the
  README's "One-time build setup" section THERE first (builds submodule/PicoDstReader_SL24y
  and runs macros/makeLibs.C) so bin/*.so are genuine Linux binaries before this XML's
  SandBox packages them.

  *** SPECIES: this template runs ONE species per job, same convention the reference
  etof job used. Make three copies of this file (or three separate submissions),
  changing only the PARTNAME line inside <command> and the job name/output paths, to
  cover PION / KAON / PROTON.

  *** CATALOG QUERY: trgsetupname copied verbatim from lightflavorspectra_etof's real,
  working pions_OO_200GeV job; library= and production= kept at SL24y/P24iy to match
  this repo's port (the reference job instead paired library=SL23c with
  production=P23ic). The runnumber whitelist from that reference job is carried over
  below - runnumbers identify actual collision runs, not the reprocessing pass, so the
  same runs should exist under P24iy/SL24y too, but this has NOT been independently
  confirmed against the current StarCatalog. Two typos in the reference job's original
  list (a single "|" instead of "||" between 22131018 and 22131019, and a stray "||||"
  between 22131065 and 22130029) have been corrected below.
  This SL24y/P24iy pairing (with the runnumber whitelist) has NOT been independently
  verified against the current StarCatalog - confirm it actually resolves to files
  before relying on it.
-->

<job name="picoBinner_OO200_PION" maxFilesPerProcess="12" fileListSyntax="xrootd" simulateSubmission="false" filesPerHour="1000" copyInputLocally="true">

  <shell>singularity exec -e -B /direct -B /star -B /afs -B /gpfs -B /sdcc/lustre02 /cvmfs/star.sdcc.bnl.gov/containers/rhic_sl7.sif</shell>

  <!-- Scheduler log files -->
  <stdout URL="file:/star/data03/scratch/liggett/picoBinner_OO200/stdout_stderr/" />
  <stderr URL="file:/star/data03/scratch/liggett/picoBinner_OO200/stdout_stderr/" />

  <!-- O+O 200 GeV production catalog query - see header note above about the
       production=/library= pairing and the runnumber whitelist before relying on this. -->
  <input URL="catalog:star.bnl.gov?filename~st_physics,trgsetupname=production_OO_200GeV_2021,production=P24iy,library=SL24y,storage=local,storage!=HPSS,filetype=daq_reco_picoDst,runnumber=22136001||22136002||22136003||22136004||22136005||22136006||22136007||22136008||22136009||22136010||22135001||22135025||22135026||22135027||22135028||22135029||22135030||22135031||22135032||22135035||22135036||22135037||22135038||22135039||22135040||22135041||22135042||22134001||22134002||22134003||22134004||22134005||22134006||22134008||22134009||22134010||22134011||22134012||22134013||22134014||22134015||22134018||22134019||22134026||22134027||22134028||22134029||22134030||22134031||22134032||22134033||22134034||22133005||22133007||22133009||22133010||22133011||22133013||22133014||22133015||22133016||22133024||22133025||22133026||22133027||22133028||22133029||22133031||22133032||22133037||22133038||22133039||22133040||22133042||22133043||22133044||22133045||22132001||22132002||22132003||22132004||22132008||22132010||22132014||22132015||22132024||22132025||22132026||22131011||22131012||22131013||22131014||22131015||22131016||22131017||22131018||22131019||22131020||22131021||22131022||22131036||22131039||22131040||22131042||22131043||22131044||22131045||22131050||22131053||22131054||22131056||22131057||22131058||22131062||22131063||22131064||22131065||22130029||22130046||22130047" nFiles="all" />

  <!-- Scheduler's own auxiliary files -->
  <Generator><Location>
    /star/data03/scratch/liggett/schedFiles/picoBinner_OO200
  </Location></Generator>

  <!--
  <ResourceUsage>
    <Memory>
      <MinMemory>2500</MinMemory>
      <MaxMemory>3500</MaxMemory>
    </Memory>
  </ResourceUsage>
  -->

  <!-- 2026-07-04: <File> paths switched from relative ("file:./...") to fully
       absolute. Relative paths turned out to be resolved by star-submit against
       whatever directory it's invoked from; when run from xml/ instead of the repo
       root, every single relative path silently failed to resolve, producing a
       SandBox zip with only empty directory entries and zero actual file content
       (confirmed via `unzip -l`: 8 entries, all 0 bytes). Absolute paths make this
       submittable from any directory. If someone else runs this, update every
       /star/u/liggett2820/lightflavorspectra_OO200 path below to their own checkout.

       Also added: headers/CutClass.h, headers/CalibrationClass.h,
       headers/HistogramUtilities.h, headers/PhysMath.h, and
       submodule/ParticleInfo/ParticleInfo/ParticleInfo.h. These are needed so Cling
       knows CutClass/CalibrationClass's declared interface when interpreting
       RunPicoBinner.C; the .so files only provide the compiled implementation, not
       the declarations the interpreter needs at parse time (same reasoning as
       LoadZFitterLibs.C's equivalent comment). Without them, RunPicoBinner.C's own
       #include line fails with "cannot open file ../headers/CutClass.h".

       IMPORTANT: do not put a comment INSIDE <Package>...</Package> between <File>
       entries. star-submit's SandBox packager appears to silently drop whatever
       <File> entries immediately follow an embedded comment (confirmed empirically:
       an earlier version of this file had the paragraph above placed between two
       <File> lines inside <Package>, and every File entry right after it was
       missing from the packaged zip, even though the files themselves existed on
       disk with normal permissions). Keep all explanatory comments outside
       <SandBox> entirely. -->
  <SandBox installer="ZIP">
    <Package name="PicoBinner_OO200">
      <File>file:/star/u/liggett2820/lightflavorspectra_OO200/makefile_toggles.h</File>
      <File>file:/star/u/liggett2820/lightflavorspectra_OO200/bin/namespaces_cxx.so</File>
      <File>file:/star/u/liggett2820/lightflavorspectra_OO200/bin/ParticleInfo_cxx.so</File>
      <File>file:/star/u/liggett2820/lightflavorspectra_OO200/bin/CalibrationClass_cxx.so</File>
      <File>file:/star/u/liggett2820/lightflavorspectra_OO200/bin/CutClass_cxx.so</File>
      <File>file:/star/u/liggett2820/lightflavorspectra_OO200/bin/PicoBinner_cxx.so</File>
      <File>file:/star/u/liggett2820/lightflavorspectra_OO200/bin/SetCutClass_C.so</File>
      <File>file:/star/u/liggett2820/lightflavorspectra_OO200/bin/libStPicoDst.so</File>
      <File>file:/star/u/liggett2820/lightflavorspectra_OO200/bin/StPicoDst_Dict_rdict.pcm</File>
      <File>file:/star/u/liggett2820/lightflavorspectra_OO200/macros/RunPicoBinner.C</File>
      <File>file:/star/u/liggett2820/lightflavorspectra_OO200/macros/LoadPicoBinnerLibs.C</File>
      <File>file:/star/u/liggett2820/lightflavorspectra_OO200/submodule/ParticleInfo/PidFunctions_Data/dev_BichselCurves.root</File>
      <File>file:/star/u/liggett2820/lightflavorspectra_OO200/headers/CutClass.h</File>
      <File>file:/star/u/liggett2820/lightflavorspectra_OO200/headers/CalibrationClass.h</File>
      <File>file:/star/u/liggett2820/lightflavorspectra_OO200/headers/HistogramUtilities.h</File>
      <File>file:/star/u/liggett2820/lightflavorspectra_OO200/headers/PhysMath.h</File>
      <File>file:/star/u/liggett2820/lightflavorspectra_OO200/submodule/ParticleInfo/ParticleInfo/ParticleInfo.h</File>
      <File>file:/star/u/liggett2820/lightflavorspectra_OO200/scripts/run_picobinner_sdcc.bash</File>
    </Package>
  </SandBox>

  <!-- starver must match the catalog query's library= tag above (SL24y). -->
  <command>

    starver SL24y

    pwd
    ls
    echo LS TO BIN:
    ls bin

    <!-- Defensive copy so ParticleInfo::ReadBichselFile()'s directory-probing logic
         (which tries cwd, cwd/.., and a couple of submodule-relative paths) is
         guaranteed to find it regardless of the SandBox's unpacked layout - matches
         the same defensive step the reference etof job takes (it copies to both
         macros/ and scripts/). -->
    cp ./submodule/ParticleInfo/PidFunctions_Data/dev_BichselCurves.root .
    cp ./dev_BichselCurves.root macros/.
    cp ./dev_BichselCurves.root scripts/.

    cd scripts

    echo starting awk command to remove numEvents after file name in list
    set newList="$PWD"/"$JOBID".list
    awk '{print $1}' ${FILELIST} > $newList

    pwd
    ls

    <!-- args: fileList outputDir PARTNAME makeBasicHistos correctT0 ignoreBTOFNonPOI doMassSquared -->
    ./run_picobinner_sdcc.bash $newList ${SCRATCH}/ PION true false false false

    <!-- Permanent output area - SCRATCH is wiped after the job -->
    mv ${SCRATCH}/*_Processed.root /star/data03/pwg/liggett/PicoBinner_OO200/SL24y_PION/
    rm ${SCRATCH}/*_Processed.root

  </command>

  <!-- Same permanent output area as the mv above -->
  <output fromScratch="*_Processed.root" toURL="file:/star/data03/pwg/liggett/PicoBinner_OO200/SL24y_PION/" />
</job>
